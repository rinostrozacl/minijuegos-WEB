# Variables de configuración para Firebase (público) — van en BUILD del Docker
NUXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NUXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Variables para servidor
PORT=3000
HOST=0.0.0.0

# Resend (runtime en Coolify). Dominio codepulse.cl debe estar verificado en Resend.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=GameCraft2026 <info@codepulse.cl>

# --- Firebase Admin (runtime en Coolify) ---
# RECOMENDADO para Coolify (evita problemas con \\n y comillas):
# 1. Descarga el JSON de Firebase (Service accounts → Generate new private key)
# 2. En tu Mac: base64 -i minijuegos-firebasekey.json | tr -d '\n'
# 3. Pega el resultado en:
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
#
# Alternativa: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# NO uses FIREBASE_PRIVATE_KEY en Coolify (se corrompe con facilidad).
